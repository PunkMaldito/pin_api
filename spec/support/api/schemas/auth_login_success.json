{
    "type": "object",
    "required": ["token", "user"],
    "properties": {
        "token": { "type": "string" },
        "user": {
            "type": "object",
            "required": ["data"],
            "properties": {
                "data": {
                    "type": "object",
                    "required": ["id", "type", "attributes"],
                    "properties": {
                        "id": { "type": "string" },
                        "type": { "type": "string", "enum": ["user"] },
                        "attributes": {
                            "type": "object",
                            "required": ["name", "email", "role", "permissions"],
                            "properties": {
                                "name": { "type": "string" },
                                "email": { "type": "string" },
                                "role": { "type": "string", "enum": ["seller", "builder", "admin"] },
                                "permissions": {
                                    "type": "object",
                                    "required": ["can_sell", "can_build", "can_manage_products"],
                                    "properties": {
                                        "can_sell": { "type": "boolean" },
                                        "can_build": { "type": "boolean" },
                                        "can_manage_products": { "type": "boolean" }
                                    }
                                },
                                "created_at": { "type": "string" },
                                "updated_at": { "type": "string" }
                            }
                        }
                    }
                }
            }
        }
    }
}
