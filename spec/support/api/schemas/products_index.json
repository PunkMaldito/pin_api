{
    "type": "object",
    "required": ["data", "meta"],
    "properties": {
        "data": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "type", "attributes"],
                "properties": {
                    "id": { "type": "string" },
                    "type": { "type": "string", "enum": ["product"] },
                    "attributes": {
                        "type": "object",
                        "required": ["name", "stock", "price"],
                        "properties": {
                            "name": { "type": "string" },
                            "stock": { "type": "integer" },
                            "price": { "type": "number" },
                            "created_at": { "type": "string" },
                            "updated_at": { "type": "string" }
                        }
                    }
                }
            }
        },
        "meta": {
            "type": "object",
            "required": ["current_page", "total_pages", "total_count", "per_page"],
            "properties": {
                "current_page": { "type": "integer" },
                "total_pages": { "type": "integer" },
                "total_count": { "type": "integer" },
                "per_page": { "type": "integer" },
                "next_page": { "type": ["integer", "null"] },
                "prev_page": { "type": ["integer", "null"] }
            }
        }
    }
}
